# Remove terminal prompt
PS1=""
trap "echo -en '\e[?1049l'" EXIT ERR

# Get total columns and lines
read -r lines columns < <(stty size)
termcenter=$(( $columns / 2 ))
splashcenter=$(( $splashlen / 2 ))
splashstart=$(( $termcenter - $splashcenter ))

echo -e "$defaultbg"
clear

if (( $splashlen > $columns + 10 )); then
    echo "Window too small"
    exit
fi

function splash_forward_line() {
    (( linepos ++ ))
    set_cursor $linepos $splashstart
}

for (( i=0; i<$splashcols; i++ )); do
    set_cursor $(( linestart + i )) $splashstart
    echo -e "${splash[$i]}"
    (( linepos++ ))
done
echo -e "$reset"

splash_forward_line

#################################################################################
#	       Get credentials -- Encrypt and store if not found		#
#################################################################################
emailenc="${HOME}/.bashmail/.emailenc"
passenc="${HOME}/.bashmail/.passenc"

if ! [[ -f "$emailenc" && -f "$passenc"  ]]; then
    echo -n "Email: "
    read -r email
    echo "$email" | openssl aes-256-cbc -pbkdf2 -pass pass:"bashmailemail"\\
    -out "$emailenc" # ~/.bashmail/.emailenc
    splash_forward_line

    echo -n "Pass: "
    read -s -r pass
    echo "$pass" | openssl aes-256-cbc -pbkdf2 -pass pass:"bashmailpass"\\
    -out "$passenc" # ~/.bashmail/.passenc
    splash_forward_line
else
    echo "Found stored credentials. Decrypting..."
    email="$(openssl aes-256-cbc -pbkdf2 -d -pass pass:"bashmailemail" -in $emailenc)"
    pass="$(openssl aes-256-cbc -pbkdf2 -d -pass pass:"bashmailpass" -in $passenc)"
    splash_forward_line
fi

imapdomain="$(echo 'imap.'$(echo $email | sed -e 's/^[^@]*@//')':993')"


#################################################################################
#				    SSL Prep					#
#################################################################################
echo "Attempting to login..."
splash_forward_line

if ! [[ -p $sendssl ]]; then
    mkfifo /var/tmp/sendssl.log
fi

if ! [[ -p $readssl ]]; then
    mkfifo /var/tmp/readssl.log
fi

# Create FDs
exec {sendfd}<>/var/tmp/sendssl.log # use $sendfd -- Send commands here
exec {readfd}<>/var/tmp/readssl.log

#################################################################################
#				  Call openssl					#
#################################################################################
hide_mode
openssl s_client -connect $imapdomain -quiet -crlf <&$sendfd >&$readfd &
sslpid=$!

# Trap to kill, restore previous terminal screen/coloring on term or error
trap "kill $sslpid; echo -en '\e[?1049l'; hide_mode_off; reset_colors" EXIT ERR

#################################################################################
#		       SSL connection and inbox selection			#
#################################################################################
while read -r line; do
    case "$line" in
	"* OK"*) # Initial connection response
	    hide_mode_off
	    splash_forward_line
	    echo "SSL connection established. Sending credentials"
	    splash_forward_line
	    echo "$A LOGIN $email $pass" >&$sendfd
	   hide_mode
	    ;;
	"$A"*"OK"*"Success"*) # Response to $A LOGIN
	    hide_mode_off
	    echo "Successfully logged in"
	    splash_forward_line
	    hide_mode
	    break
	    ;;
	*"BAD"*) # Failed response of any kind
	    echo "Failed to login"
	    rm $emailenc $passenc
	    ;;

	*)
	    continue
	    ;;
    esac
done <&$readfd

get_unread_messages
fetch_header_field $unread_str
parse_headers
clearfifo
hide_mode_off
draw_unread

##################################################################################
#				   BOTTOM BAR					 #
#			   Show cursor position range				 #
#				   Ex: (2/10)					 #
##################################################################################
bottom_text="" # Store globally to track the length between changes
bottomline=$lines
set_bottom_bar

# After bottom bar is set, rehighlight message at cursor
highlight

message_bs=""

unread_nav_mode

rm $sendssl $readssl
