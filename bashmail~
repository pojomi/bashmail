function clearfifo() {
    while read -t 0.5 line; do
	continue
    done <&$readfd
}

function get_unread_messages() {
    # Send request to server for list of unread message IDs
    # Store in array $unread
    # 0 args check is the initial call only
    if (( $# == 0 )); then
	echo "$A SELECT INBOX" >&$sendfd
	while read line; do
	    if [[ "$line" =~ \(Success\) ]]; then
		hide_mode_off
		echo "Inbox selected"
		splash_forward_line
		hide_mode
		break
	    elif [[ "$line" =~ BAD|Fail ]]; then
		echo "Failed inbox selection"
		sleep 2s
		exit
	    fi
	done <&$readfd
    fi
    echo "$A SEARCH X-GM-RAW \"in:unread\"" >&$sendfd
     while read line; do
	if [[ "$line" =~ OK.*Success ]]; then
	    break
	elif [[ "$line" =~ BAD|Fail ]]; then
	    echo "Failed unread search"
	    sleep 3s
	    exit
	elif [[ "$line" =~ SEARCH" "([0-9].*) ]]; then
	    id_str="${breg[1]//$'\r'/}"
	    unread=($(echo "${id_str// /$'\n'}"))
	    unread_str="${id_str// /,}"
	    unreadcount=${#unread[@]}
	    # Store the terminal line numbers
	    firstunread=2
	    lastunread=$(( unreadcount * 2))
	    linepos=2
	    prevlinepos=0
	fi
    done <&$readfd
}

function reset_indexes() {
    # Unset all indexes of any passed array names
    # Args should be strings not prefixed with "$"
    for i in $(seq 1 $#); do
	# Expand $i with ${!i} to get the string from $1,2,3...
	declare -n arg_arr=${!i}
	unset arg_arr[@]
    done
}

function fetch_header_field() {
    clearfifo
    echo "$A FETCH $1 body.peek[header.fields (from subject)]" >&$sendfd
    i=0
    while read line; do
	if [[ "$line" =~ OK.*Success|BAD ]]; then break; fi
	if [[ "$line" =~ \{[0-9]+\} ]]; then
	    bytes=$(echo "${breg//["{"|"}"|$'\n']/}")
	    if (( bytes > 0 )); then
		read -N $bytes body <&$readfd
		regex1="From: (.*)Subject"
		regex2="From: (.*)"
		if [[ "$body" =~ $regex1 || "$body" =~ $regex2 ]]; then
		    regval="${breg[1]//[$'\n'|\"]/}"
		    regex1="^([^\<]*)"
		    regex2="^(\<.*\>)"
		    if [[ "$regval" =~ $regex1 || "$regval" =~ $regex2 ]]; then
			from_arr[$i]=${breg[1]//[<>]/}
		    else
			from_arr[$i]=$regval
		    fi
		    regex1="Subject: (.*)From"
		    regex2="Subject: (.*)"
		    if [[ "$body" =~ $regex1 || "$body" =~ $regex2 ]]; then
			subject_arr[$i]="${breg[1]//[$'\n'|\"]/}"
		    fi
		    (( i++ ))
		fi
	    fi
	fi
    done <&$readfd
}

function parse_headers() {
    for (( i=0;i<$unreadcount;i++ )); do
	if [[ "${from_arr[$i]}" =~ \?B\? ]]; then
	    from_arr[$i]=$(decode_b64 from_arr $i);
	fi
	if [[ "${from_arr[$i]}" =~ \?Q\? ]]; then
	    from_arr[$i]=$(decode_qp --header "${from_arr[$i]}");
	fi
	if [[ "${subject_arr[$i]}" =~ \?B\? ]]; then
	    subject_arr[$i]=$(decode_b64 subject_arr $i);
	fi
	if [[ "${subject_arr[$i]}" =~ \?Q\? ]]; then
	    subject_arr[$i]=$(decode_qp --header "${subject_arr[$i]}");
	fi
    done
}

function draw_popup() {
    # $1 popup array box var name (no "$")
    # $2 flag for type of popup; Currently only "--warn"
    declare -n error_arr=$1
    box_len=${#error_arr[0]}
    box_lines=${#error_arr[@]}
    box_line_center=$(( box_lines / 2))
    box_col_center=$(( box_len / 2))
    tty_start_col=$(( columns / 2 - box_col_center ))
    tty_start_line=$(( lines / 2 - box_line_center ))

    hide_cursor
    if [[ "$2" == "--warn" ]]; then
	echo -en "$Ybg$Black"
    else
	echo -en "$Gbg$Black"
    fi
    for (( i=0;i<box_lines;i++ )); do
	set_cursor $tty_start_line $tty_start_col
	(( tty_start_line++ ))
	echo -en "${error_arr[i]}"
    done
    if [[ "$2" == "--warn" ]]; then
	read -n 1 -t 3 close_error
	reset_colors
	draw_unread
	highlight
    fi
}
    

function draw_unread() {
    # Clear the terminal
    clear
    hide_cursor
    set_cursor 0 0

    # Add a header line
    echo -e "$BrBlackbg  [Unread]$reset"

    # Decrement to sort newest first
    for (( i=$unreadcount-1; i>-1; i-- )); do
	reset_colors
	echo -e " $R${from_arr[$i]}"
	reset_colors
	echo -e " $Y${subject_arr[$i]}"
    done
    set_cursor $linepos 1

    if [[ -n "$bottom_text" ]]; then
	set_bottom_bar
    fi
}

function reload_unread() {
    clearfifo
    reset_indexes unread from_arr subject_arr
    reset_colors
    get_unread_messages --reload
    fetch_header_field $unread_str
    parse_headers
    draw_unread
    set_bottom_bar
    highlight
}

# Relevant index of message
# $1: Either $prevlinepos or $linepos
function rel_msg_index() {
    declare -i selected_line=$1
    echo $(( (lastunread - selected_line) / 2 ))
}

# To print the visibly highlighted index
function bottom_msg_at_cursor() {
    echo $(( linepos / 2 ))
}

function set_bottom_bar() {
    bottom_text="($(bottom_msg_at_cursor)/$unreadcount)"
    bottom_unused_cols=$(( columns - ${#bottom_text} - 1 ))
    set_cursor $bottomline 1
    erase_line
    echo -en "$Rbg$Black$Bold $bottom_text"
    for (( i=0; i<$bottom_unused_cols; i++ )); do
	echo -n " "
    done
    set_cursor $linepos 1
}

function update_bottom_bar() {
    if (( unreadcount > 1 )); then
	hide_cursor
	bottom_text_len=${#bottom_text}
	set_cursor $bottomline 1
	bottom_text="($(bottom_msg_at_cursor)/$unreadcount)"
	bottom_text_diff=$(( $bottom_text_len - ${#bottom_text} ))
	if (( bottom_text_diff > 0 )); then
	    for (( i=0; i<$bottom_text_diff; i++ )); do
		bottom_text+=" "
	    done
	fi
	echo -en "$Rbg$Black$Bold $bottom_text"
	set_cursor $linepos 1
#	show_cursor
    fi
}

function highlight() {
    prev_msg_index=$(rel_msg_index $prevlinepos)
    line_msg_index=$(rel_msg_index $linepos)

    if (( prevlinepos > 0 )); then
	set_cursor $prevlinepos 1
	reset_colors
	echo -e " $R${from_arr[$prev_msg_index]}"
	#	forward_line
	reset_colors
	echo -e " $Y${subject_arr[$prev_msg_index]}"
    fi

    set_cursor $linepos 1
    reset_colors
    echo -e " $R$Bbg$Bold${from_arr[$line_msg_index]}"
    #    forward_line
    reset_colors
    echo -e " $Y$Bbg$Bold${subject_arr[$line_msg_index]}"

    set_cursor $linepos 1
}


##################################################################################
#				    NAVIGATION					 #
##################################################################################
function inbox_list_forward() {
    if (( unreadcount > 1 )); then
	linesum=$(( 2 + linepos ))
	# Wrap at last message
	if (( linesum >= lastunread + 1 )); then
	    set_cursor $firstunread 1
	    prevlinepos=$linepos
	    linepos=$firstunread
	    highlight
	    update_bottom_bar
	else
	    set_cursor $linesum 1
	    prevlinepos=$linepos
	    (( linepos += 2 ))
	    highlight
	    update_bottom_bar
	fi
    fi
}

function inbox_list_backward() {
    if (( unreadcount > 1 )); then
	linesum=$(( linepos - 2 ))
	# Wrap at first message
	if (( linesum <= firstunread - 1 )); then
	    set_cursor $lastunread 1
	    prevlinepos=$linepos
	    linepos=$lastunread
	    highlight
	    update_bottom_bar
	else
	    set_cursor $linesum 1
	    prevlinepos=$linepos
	    (( linepos -= 2 ))
	    highlight
	    update_bottom_bar
	fi
    fi
}

function unread_nav_mode() {
    while read -s -n 1 key; do
	case "$key" in
	    "")
		inbox_list_forward
		;;
	    "")
		inbox_list_backward
		;;
	    r)
		draw_popup popup_reloading
		reload_unread
		;;
	    j)
		inbox_list_forward
		;;
	    k)
		inbox_list_backward
		;;
	    "")
		get_mime_structure unread
		;;
	    "")
		break
		;;
	    q)
		break
		;;
	esac
    done
}

function message_nav_mode () {
    while read -s -n 1 key; do
	case "$key" in
	    $'\e')
		draw_unread
		highlight
		break
		;;
	    q)
		reset_indexes open_message
		draw_unread
		highlight
		break
		;;
	    b)
		draw_previous_page
		;;
	    f)
		draw_next_page
		;;
	    j)
		forward_line
		;;
	    k)
		backward_line
		;;
	    h)
		backward_column
		;;
	    l)
		forward_column
		;;
	    "")
		forward_column
		;;
	    "")
		backward_column
		;;
	    "")
		forward_line
		;;
	    "")
		backward_line
		;;
	esac
    done
}
