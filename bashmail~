function get_mime_structure() {
    clearfifo
    declare -n unread_arr=$1
    selected_message=${unread_arr[$(rel_msg_index $linepos)]}
    declare -A structure
    response=""; container=""; parens=""
    declare -i paren_count
    structure[id]="$selected_message"
    structure[encoding]="none"
    echo "$A FETCH $selected_message BODYSTRUCTURE" >&$sendfd
    while read line; do
	if [[ "$line" =~ OK.*Success|BAD ]]; then break; fi
	response+="$line"
    done <&$readfd
    # [1] is the parens. [2] is the format. [3] is the rest of the container.
    if [[ "$response" =~ BODYSTRUCTURE[^\(]*(\({1,})([^ ]{1,}" "[^ ]{1,})([^\)]*\)){2} ]]; then
	parens="${breg[1]}"
	structure[format]="${breg[2]}"
	container="${breg[@]:2:2}"
    fi
    [[ "$container" =~ "QUOTED-PRINTABLE" ]] && structure[encoding]="qp"
    if (( ${#parens} > 0 )); then
	paren_count=$(( ${#parens}-1 ))
	(( paren_count == 3 )) && structure[leaf]="1.1.1"
	(( paren_count == 2 )) && structure[leaf]="1.1"
	(( paren_count == 1 )) && structure[leaf]="1"
    fi
    if [[ "${structure[format]}" =~ HTML ]]; then
	draw_popup popup_html_warn --warn
	return
    fi

    get_message structure
}

function get_message() {
    # $1: AA structure
    declare -n struct=$1
    declare -i count=0
    echo "$A FETCH ${struct[id]} body.peek[${struct[leaf]}]" >&$sendfd
    read bytes <&$readfd
    [[ "$bytes" =~ \{([0-9]{1,})\} ]] && bytes="${breg[1]}"
    read -N $bytes message <&$readfd
    while read line; do
	open_message[$count]="$line"
	(( count++ ))
    done < <(echo "$message")
    if [[ "${struct[encoding]}" == "none" ]]; then
	parse_plain_links
	message_cleanup_whitespace
	print_message
    elif [[ "${struct[encoding]}" == "qp" ]]; then
	decode_qp --message
	parse_plain_links
	message_cleanup_whitespace
	print_message
    fi
}

# $1: namespace $2: index
function decode_b64() {
    declare -n arr=$1
    full_string="${arr[$2]}"
    full_string="${full_string//$'\n'/}"
    [[ ! "$full_string" =~ \?= ]] && echo "End of Base64 not found"
    [[ "$full_string" =~ ^[^=]* && ${#breg} > 0 ]] && plain_pre="$breg"
    [[ "$full_string" =~ =\?.{5}\?B\?.*=\? ]] && stripped="$breg"
    regexsed="s/(=\?.{5}\?B\?)|(=?\?=)|([[:space:]])//g"
    encoded=$(echo "${stripped//$'\n'/}"|sed -r "$regexsed")
    # Sometimes base64 is printing errors when everything seems to load fine.
    # For now, redirecting stderr to /dev/null
    decoded=$(echo "$encoded"|base64 -d 2>/dev/null)
    [[ -v plain_pre ]] && echo "$plain_pre$decoded" || echo "$decoded"
}

function decode_qp() {
    # If $1 is array, sed the whole thing here ***TODO: tweak args***
    clearfifo
    if [[ "$1" == "--message" ]]; then
	declare -n arg1=$2
	for (( i=0;i<${#open_message[@]};i++ )); do
	    open_message[$i]=$(echo "${open_message[$i]}"\
				   |sed -r 's/=([A-Za-z0-9]{2})/\\x\1/g;s/=//g')
	done
    elif [[ "$1" == "--header" ]]; then
	string="${2//$'\n'/}"
	[[ "$string" =~ ^[^=]* && ${#breg} > 0 ]] && string_pre_qp="$breg"
	[[ "$string" =~ ^.*=\?.{5}\?Q\?(.*)\?= ]] && string_qp="${breg[1]//$'\n'/}"
	if [[ -v string_qp && ${#string_qp} > 0 ]]; then
	    regex="=([A-Za-z0-9]{2})"
	    qp_message=$(echo "$string_qp"|sed -r "s/_/ /g; s/$regex/\\\x\1/g")
	    [[ -v string_pre_qp ]] && echo -e "$string_pre_qp$qp_message"\
		    || echo -e "$qp_message"
	else
	    echo "Failed to decode text"
	fi
    fi
}

function parse_html() {
    clearfifo
    for (( i=0;i<${#open_message[@]};i++ )); do
	open_message[$i]=$(echo "${open_message[$i]}"\
			       |sed -r 's/<br>/\n/g; s/<\/?.*>//g')
    done
}

function parse_plain_links() {
    for (( i=0;i<${#open_message[@]};i++ )); do
	open_message[$i]=$(echo "${open_message[$i]}"\
	  |sed -r "s/[(<]?.?(https?|mailto).*[)>[:blank:]]?/\\${BrB}Link\\$reset/g")
    done
}

function message_cleanup_whitespace() {
    # Any groups of 3 or more consecutive new lines, reduce to 2
    for (( i=0;i<${#open_message[@]};i++ )); do
	if [[ "${open_message[$i]}" =~ ^$'\n' &&\
		  "${open_message[$i+1]}" =~ ^$'\n' &&\
		  "${open_message[$i+2]}" =~ ^$'\n' ]]; then
	    unset open_message[$i+2]
	fi
    done
}

function print_message() {
    reset_colors
    clear
    for (( i=0;i<$lines;i++ )); do
	if [[ -v open_message[$i] ]]; then
	    set_cursor $i 0
	    echo -en "${open_message[$i]}"
	    
	else
	    break
	fi
    done
    open_message_range[0]=0
    open_message_range[1]=$(( lines - 1 ))
    set_cursor 0 0
    message_line_pos=1
    show_cursor
    message_nav_mode
}

