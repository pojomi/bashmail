function save_screen() {
    echo -en '\e[?1049h'
}

function restore_screen() {
    echo -en '\e[?1049l'
}

function forward_line () {
    if (( message_line_pos == lines && open_message_range[1] >= lines - 1)); then
	redraw_bottom_message_line
    else
	echo -en '\e[1E'
	(( message_line_pos++ ))
    fi
}

function backward_line () {
    if (( message_line_pos == 0 && open_message_range[0] > 0 )); then
	redraw_top_message_line
    else
	echo -en '\e[1F'
	(( message_line_pos-- ))
    fi
}

function redraw_top_message_line() {
    # Draw a blank line at line 1
    echo -en '\e[1T'
    set_cursor 0 0
    hide_cursor
    #    (( message_line_pos-- ))
    (( open_message_range[0]-- ))
    (( open_message_range[1]-- ))
    echo -en "${open_message[${open_message_range[0]}]}"
    set_cursor 0 0
    show_cursor
}

function redraw_bottom_message_line() {
    # Draw a blank line at bottom line
    if (( open_message_range[1] < ${#open_message[@]} - 1 )); then
	echo -en '\e[1S'
	set_cursor $lines 0
	hide_cursor
	(( open_message_range[0]++ ))
	(( open_message_range[1]++ ))
	echo -en "${open_message[${open_message_range[1]}]}"
	set_cursor $lines 0
	show_cursor
    fi
}

function draw_previous_page() {
    # If line 1 is > message index 0, draw previous n $lines on screen
    # If message index 0 is reached, stop there, print on line 1 through n $lines
    open_message_range[0]=$(( open_message_range[0] - lines ))
    open_message_range[1]=$(( open_message_range[0] + lines - 1 ))
    if (( open_message_range[0] >= 0 )); then
	# Define index 1 first to reference current index 0 as start point
	hide_cursor
	clear
	set_cursor 0 0
	for (( i=0;i<lines;i++ )); do
	    set_cursor $i 0
	    echo -en "${open_message[open_message_range[0]+i]}"
	done
	set_cursor 0 0
	message_line_pos=1
	show_cursor
    else
	hide_cursor
	clear
	for (( i=0;i<lines;i++ )); do
	    set_cursor $i 0
	    echo -en "${open_message[i]}"
	done
	set_cursor 0 0
	show_cursor
	open_message_range[0]=0
	open_message_range[1]=$(( open_message_range[0] + lines - 1))
	message_line_pos=1
    fi
}

function draw_next_page() {
    # If there are >=n $lines ahead in message indexes, print n lines
    # Else, print any remainder < n $lines
    # If end of message visible, do nothing
    message_remaining_lines=$(( ${#open_message[@]} - open_message_range[1] + 1 ))
    open_message_range[0]=$(( open_message_range[1] + 1 ))
    if (( message_remaining_lines >= lines )); then
	open_message_range[1]=$(( open_message_range[0] + lines - 1 ))
	hide_cursor
	clear
	set_cursor 0 0
	for (( i=0;i<lines;i++ )); do
	    set_cursor $i 0
	    echo -en "${open_message[open_message_range[0]+i]}"
	done
	set_cursor 0 0
	message_line_pos=1
	show_cursor
    elif (( message_remaining_lines > 0 )); then
	open_message_range[1]=$(( open_message_range[0] + message_remaining_lines - 1 ))
	hide_cursor
	clear
	for (( i=0;i<message_remaining_lines;i++ )); do
	    set_cursor $i 0
	    echo -en "${open_message[i]}"
	done
	set_cursor 0 0
	show_cursor
	message_line_pos=1
    fi
}

